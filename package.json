{
  "name": "ciabatta-cup",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "docs:check": "node scripts/check-docs.mjs",
    "docs:check:test": "node --test scripts/check-docs.test.mjs",
    "docs:impact": "node scripts/check-docs-impact.mjs",
    "docs:impact:test": "node --test scripts/check-docs-impact.test.mjs",
    "test:e2e": "node scripts/run-e2e.mjs",
    "test:performance": "playwright test --config=playwright.performance.config.ts",
    "assets:trophies:check": "node scripts/check-trophy-assets.mjs",
    "test:integration": "vitest run tests/integration/ranked-lifecycle.test.ts",
    "db:start": "supabase start",
    "db:test": "node scripts/run-db-tests.mjs",
    "db:lint": "supabase db lint --level warning",
    "verify": "npm run lint && npm run typecheck && npm run test && npm run assets:trophies:check && npm run docs:check && npm run docs:check:test && npm run docs:impact && npm run docs:impact:test && npm run build && npm run test:performance && npm run test:e2e",
    "preflight": "npm run verify"
  },
  "dependencies": {
    "@google/model-viewer": "^4.3.1",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.110.2",
    "next": "16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-easy-crop": "^6.2.2",
    "server-only": "^0.0.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "gltf-validator": "^2.0.0-dev.3.10",
    "supabase": "^2.109.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.10"
  }
}
